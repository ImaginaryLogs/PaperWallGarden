---
interface Props {
  to: string;      // "garden:slug" or "playground:slug"
  label?: string;
}

const { to, label } = Astro.props;
const [section, path] = to.split(':');
const href    = section === 'garden' ? `/garden/${path}` : `/playground/${path}`;
const icon    = section === 'garden' ? '🌿' : '⚗️';
const secText = section === 'garden' ? 'Digital Garden' : 'Playground';
const display = label ?? path;
---

<a href={href} class="cross-link">
  <span>{icon}</span>
  <span class="cross-link__section">{secText} /</span>
  <span>{display}</span>
  <span class="cross-link__arrow">↗</span>
</a>