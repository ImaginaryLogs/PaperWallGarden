---
import '../../styles/global.css';
import '../../styles/garden.css';
import '../../styles/playground.css';

interface Props {
  title?: string;
  description?: string;
  section?: 'garden' | 'playground' | 'home';
  tags?: string[];
  backlinks?: Array<{ slug: string; title: string }>;
}

const {
  title       = 'PaperWallGarden',
  description = 'A digital garden and interactive developer playground.',
  section     = 'home',
  tags        = [],
  backlinks   = [],
} = Astro.props;

const base = import.meta.env.BASE_URL ?? '/';

---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === 'PaperWallGarden' ? title : `${title} — PaperWallGarden`}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
    <link 
    rel="stylesheet" 
    href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" 
    integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV" 
    crossorigin="anonymous"
  >
  </head>
  <body>
    <div class="site-grid-bg" aria-hidden="true"></div>

    <nav class="site-nav" role="navigation" aria-label="Main navigation">
      <a href={base} class="site-nav__logo" aria-label="Home">
        <span class="site-nav__logo-mark">⬡</span>
        <span class="site-nav__logo-text">PaperWallGarden</span>
      </a>
      <div class="site-nav__links">
        <a
          href={`${base}garden`}
          class:list={['site-nav__link', { 'site-nav__link--active': section === 'garden' }]}
        >
          <span class="site-nav__link-icon">🌿</span>Digital Garden
        </a>
        <a
          href={`${base}playground`}
          class:list={['site-nav__link', { 'site-nav__link--active': section === 'playground' }]}
        >
          <span class="site-nav__link-icon">⚗️</span>Playground
        </a>
      </div>
      <div class="site-nav__actions">
        <button id="theme-toggle" class="site-nav__icon-btn" aria-label="Toggle theme">
          <span class="theme-icon theme-icon--dark">◑</span>
          <span class="theme-icon theme-icon--light">◐</span>
        </button>
        <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="site-nav__icon-btn" aria-label="GitHub">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
        </a>
      </div>
    </nav>

    <div class="site-layout" data-section={section}>
      {section !== 'home' && (
        <aside class="site-sidebar" aria-label="Sidebar navigation">
          <div class="sidebar-section">
            <span class="sidebar-label">SECTION</span>
            {section === 'garden' ? (
              <div class="sidebar-section-links">
                <a href={`${base}garden`} class="sidebar-link"><span>🗺️</span> All Notes</a>
                <a href={`${base}garden/graph`} class="sidebar-link"><span>🕸️</span> Graph View</a>
              </div>
            ) : (
              <div class="sidebar-section-links">
                <a href={`${base}playground`} class="sidebar-link"><span>🧪</span> All Experiments</a>
              </div>
            )}
          </div>
          {tags.length > 0 && (
            <div class="sidebar-section">
              <span class="sidebar-label">TAGS</span>
              <div class="sidebar-tags">
                {tags.map(tag => (
                  <span class="sidebar-tag">#{tag}</span>
                ))}
              </div>
            </div>
          )}
          {backlinks.length > 0 && (
            <div class="sidebar-section">
              <span class="sidebar-label">BACKLINKS</span>
              <div class="sidebar-backlinks">
                {backlinks.map(bl => (
                  <a href={`${base}garden/${bl.slug}`} class="sidebar-backlink">
                    <span class="sidebar-backlink__arrow">←</span>
                    {bl.title}
                  </a>
                ))}
              </div>
            </div>
          )}
        </aside>
      )}
      <main class="site-main" id="main-content">
        <slot />
      </main>
    </div>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <span class="site-footer__copy">PaperWallGarden — <a href="https://astro.build" target="_blank" rel="noopener">Astro</a></span>
        <div class="site-footer__links">
          <a href={`${base}garden`}>Garden</a>
          <span aria-hidden="true">·</span>
          <a href={`${base}playground`}>Playground</a>
        </div>
      </div>
    </footer>

    <script>
      const html = document.documentElement;
      const btn  = document.getElementById('theme-toggle');
      const stored = localStorage.getItem('pwg-theme');
      if (stored) html.setAttribute('data-theme', stored);
      btn?.addEventListener('click', () => {
        const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('pwg-theme', next);
      });
    </script>
  </body>
</html>