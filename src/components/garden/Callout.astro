---
interface Props {
  target: string;   // raw [[target]] text
  label?: string;   // optional [[target|label]]
  exists?: boolean; // false = broken link style
}

const { target, label, exists = true } = Astro.props;

const slug = target
  .split('#')[0]
  .trim()
  .split('/')
  .pop()!
  .replace(/\.md$/i, '')
  .toLowerCase()
  .replace(/\s+/g, '-')
  .replace(/[^\w-]/g, '');

const displayText = label ?? target.split('/').pop()!.replace(/\.md$/i, '');
const href = exists ? `/garden/${slug}` : '#';
---

<a
  href={href}
  class:list={['wikilink', { 'wikilink--broken': !exists }]}
  data-target={target}
  title={exists ? `Go to: ${displayText}` : `Missing note: ${displayText}`}
>
  <span class="wikilink-bracket">[[</span>{displayText}<span class="wikilink-bracket">]]</span>
</a>