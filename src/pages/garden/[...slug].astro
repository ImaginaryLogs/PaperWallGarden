---
// src/pages/garden/[...slug].astro  (canvas branch)
import { getCollection } from 'astro:content';
import ObsidianCanvas from '../../components/garden/ObsidianCanvas';
import Layout from '../../components/shared/Layout.astro';
import { readFile } from 'node:fs/promises';
import path from 'node:path';

export async function getStaticPaths() {
  // Find all .canvas files in the vault
  const canvasFiles = await glob('obsidian/**/*.canvas');
  return canvasFiles.map(f => ({
    params: { slug: f.replace('obsidian/', '').replace('.canvas', '') },
    props: { filePath: f },
  }));
}

const { filePath } = Astro.props;
const canvasJson = JSON.parse(await readFile(filePath, 'utf-8'));
const title = path.basename(filePath, '.canvas');
---

<Layout>
  <!-- client:only prevents SSR of the React Flow canvas -->
  <ObsidianCanvas canvasJson={canvasJson} title={title} client:only="react" />
</Layout>