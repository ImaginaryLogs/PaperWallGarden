---
import { glob } from 'glob';
import fs from 'node:fs/promises';
import path from 'node:path';
import Layout from '../../components/shared/Layout.astro';
import ObsidianCanvas from '../../components/garden/ObsidianCanvas';

export async function getStaticPaths() {
  // Find all canvas layout structures present in the vault
  const canvasFiles = await glob('obsidian/**/*.canvas');
  return canvasFiles.map(file => {
    const relativePath = file.replace('obsidia/', '').replace('.canvas', '');
    const slugFragment = relativePath.replace(/\s+/g, '-').toLowerCase();
    return {
      params: { canvas: slugFragment },
      props: { filePath: file },
    };
  });
}

const { filePath } = Astro.props;
const fileContent = await fs.readFile(filePath, 'utf-8');
const canvasJson = JSON.parse(fileContent);
const canvasTitle = path.basename(filePath, '.canvas');
---

<Layout title={`${canvasTitle} (Canvas Map) | Digital Garden`}>
  <!-- client:only handles matching rendering conditions cleanly across React Flow layers -->
  <ObsidianCanvas canvasJson={canvasJson} title={canvasTitle} client:only="react" />
</Layout>